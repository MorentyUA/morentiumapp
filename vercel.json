{
          "rewrites": [
                        {
                                          "source": "/api/(.*)",
                                          "destination": "/api/$1"
                        },
                        {
                                          "source": "/(.*)",
                                          "destination": "/index.html"
                        }
          ],
          "functions": {
                        "api/youtube.ts": {
                                          "includeFiles": "api/_youtube/**"
                        }
          }
}
